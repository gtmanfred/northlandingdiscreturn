# Required — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Postgres password — defaults to "secret" for local dev (override if needed)
# POSTGRES_PASSWORD=secret

# Google OAuth — register at https://console.cloud.google.com
# Authorized redirect URI for local dev: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio — leave blank to disable SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Comma-separated list of emails that are always admins (promoted on startup and at login)
# Seed admins cannot be demoted via the admin API.
ADMIN_EMAILS=

# Supabase local dev — pre-baked tokens safe to commit
# JWT_SECRET must be at least 32 chars; ANON/SERVICE keys are JWTs signed with it
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWxvY2FsIiwiaWF0IjoxNzc2NzgzODA1LCJleHAiOjIwOTIxNDM4MDV9.aHBV7EEwjnno29EVnTycoeC-PXdPHp0DSDof3psZXaQ
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UtbG9jYWwiLCJpYXQiOjE3NzY3ODM4MDUsImV4cCI6MjA5MjE0MzgwNX0.Mhdb9yax_M05Zns7EMFQty7SmBjsfnhWFT3X-uK7w9E
